# App
NODE_ENV=development
PORT=4000
APP_NAME=CareerPointAcademy
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
ADMIN_FRONTEND_URL=http://localhost:3001

# Database (Postgres)
DATABASE_URL=postgresql://user:password@host:5432/dbname?schema=public

# Redis (queues, cache, rate limits)
# Use either REDIS_URL or REDIS_HOST/REDIS_PORT (+ optional password)
REDIS_URL=redis://:password@host:6379
REDIS_HOST=host
REDIS_PORT=6379
REDIS_PASSWORD=password

# JWT/Auth
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Super Admin Seed
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=change_me
SEED_ON_BOOT=true
SEED_DEFAULT_CATALOG=true
SEED_SAMPLE_DATA=false
DEMO_STUDENT_EMAIL=student@seed.local
DEMO_STUDENT_PASSWORD=SeedPass@123

# MinIO
MINIO_ENDPOINT=host
MINIO_PORT=9000
MINIO_ACCESS_KEY=minio_access_key
MINIO_SECRET_KEY=minio_secret_key
MINIO_BUCKET=academy
MINIO_USE_SSL=false
MINIO_REGION=
MINIO_PATH_STYLE=false
MINIO_SKIP_BUCKET_CHECK=false
MINIO_DEBUG_ERRORS=false

# File limits
MAX_PDF_BYTES=52428800
MAX_IMAGE_BYTES=2097152

# Watermark / Anti-piracy
WATERMARK_SECRET=change_me_watermark

# PhonePe (required)
PHONEPE_CLIENT_ID=your_client_id
PHONEPE_CLIENT_SECRET=your_client_secret
PHONEPE_CLIENT_VERSION=1
PHONEPE_ENV=SANDBOX
PHONEPE_REDIRECT_URL=https://your-domain.com/student/payments/return
PHONEPE_CALLBACK_USERNAME=
PHONEPE_CALLBACK_PASSWORD=
# Legacy fallback variable names (optional)
PHONEPE_WEBHOOK_BASIC_USER=
PHONEPE_WEBHOOK_BASIC_PASS=

# PhonePe recurring advanced options (optional)
PHONEPE_SUBSCRIPTION_SETUP_FLOW_TYPE=SUBSCRIPTION_CHECKOUT_SETUP
PHONEPE_SUBSCRIPTION_TYPE=RECURRING
PHONEPE_SUBSCRIPTION_PRODUCT_TYPE=UPI_MANDATE
PHONEPE_SUBSCRIPTION_AUTH_WORKFLOW_TYPE=TRANSACTION
PHONEPE_SUBSCRIPTION_AMOUNT_TYPE=FIXED
PHONEPE_SUBSCRIPTION_FREQUENCY=ON_DEMAND
PHONEPE_SUBSCRIPTION_REDEMPTION_FLOW_TYPE=SUBSCRIPTION_REDEMPTION
PHONEPE_SUBSCRIPTION_RETRY_STRATEGY=STANDARD_RETRY
PHONEPE_SUBSCRIPTION_AUTO_DEBIT=true
PHONEPE_SUBSCRIPTION_NOTIFY_BEFORE_EXECUTE=true
PHONEPE_SUBSCRIPTION_MANDATE_VALIDITY_DAYS=3650

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=apikey_or_user
SMTP_PASS=secret
SMTP_FROM=no-reply@example.com
SMTP_SECURE=false

# Logging
LOG_LEVEL=info
LOG_NOTE_ACCESS_SAMPLE_RATE=0.3

# Search
ENABLE_PG_TRGM=true

# Print worker
PRINT_WORKER_CONCURRENCY=1

# Security
REQUEST_ID_HEADER=X-Request-Id
BODY_SIZE_LIMIT=5mb

# Runtime values below are now editable in:
# Admin Panel -> CMS -> Settings -> Site Settings
# and stored in DB key: app.site_settings
#
# STUDENT_SINGLE_SESSION_ENFORCEMENT
# STUDENT_SINGLE_SESSION_STRATEGY
# NOTE_VIEW_SESSION_TTL_MINUTES
# NOTE_VIEW_MAX_SESSIONS
# NOTE_ACCESS_RATE_LIMIT
# NOTE_ACCESS_RATE_WINDOW_SECONDS
# THROTTLE_TTL_SECONDS
# THROTTLE_LIMIT
# AUTH_THROTTLE_LIMIT
# PAYMENTS_THROTTLE_LIMIT
# SEARCH_THROTTLE_LIMIT
# PHONEPE_PAYMENT_MESSAGE
# PHONEPE_DISABLE_PAYMENT_RETRY
# PHONEPE_PUBLISH_EVENTS
# SUBSCRIPTION_STACKING
# SUBSCRIPTION_RENEWAL_WINDOW_DAYS
# SUBSCRIPTION_LIFETIME_DAYS
# PENDING_ORDER_EXPIRE_MINUTES
# PAYMENTS_RECONCILE_INTERVAL_SECONDS
# PAYMENTS_AUTOPAY_INTERVAL_SECONDS
# PAYMENTS_AUTOPAY_RETRY_MINUTES
# PAYMENTS_AUTOPAY_REMINDER_HOURS
# CMS_PUBLIC_KEYS
# CMS_STUDENT_KEYS
# PRINT_MAX_QUESTIONS
# PRINT_MAX_EMBEDDED_IMAGE_BYTES
# PRINT_FAKE_PDF
# PRINT_FORCE_INLINE_PROCESSING
# PRINT_REQUEUE_ON_BOOT_LIMIT
# PRINT_AUTO_INSTALL_PLAYWRIGHT_CHROMIUM
# PRINT_PAPER_BRAND_NAME
# PRINT_PAPER_BRAND_META
# PRINT_FONTS_DIR
